    private void jButton2ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jButton2ActionPerformed
   
    try {
        String studentNo = jTextField2.getText();
        String name = jTextField3.getText();
        String surname = jTextField4.getText();
       char gender;
if (jRadioButton1.isSelected()) {
    gender = 'F';
} else if (jRadioButton2.isSelected()) {
    gender = 'M';
} else {
    JOptionPane.showMessageDialog(this, "Please select gender");
    return;
}

        String nationality = (String) jComboBox1.getSelectedItem();
        String birth = birthday.getText(); // yyyy-MM-dd

        Student.addStudentDB(studentNo, name, surname, gender, nationality, birth);

        loadStudentTable();

        JOptionPane.showMessageDialog(this, "Student saved to database!");

    } catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "Error while saving student!");
    }
    }//GEN-LAST:event_jButton2ActionPerformed
private void loadStudentTable() {
    DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
    model.setRowCount(0);

    for (Student s : Student.getAllStudentsDB()) {
        model.addRow(new Object[]{
            s.getStudentId(),
            s.getStdNo(),
            s.getFirstName(),
            s.getLastName(),
            s.getGender(),
            s.getNationality(),
            s.getBirthday()
        });
    }
}

