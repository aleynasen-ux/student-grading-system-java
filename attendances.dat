    private void loadGradesTable() {
    DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
    model.setRowCount(0);

    for (Grades g : Grades.getAllGradesDB()) {
        model.addRow(new Object[]{
            g.getGradeId(),
            g.getStudentId(),
            g.getCourseId(),
            g.getMidterm(),
            g.getFin(),
            g.getAverage(),
            g.getLetter()
        });
    }
}

